{
  "name": "relevo",
  "version": "0.3.2",
  "description": "A multi-agent coding workspace for coordinating local AI coding CLIs with shared context and native session resume.",
  "type": "module",
  "bin": {
    "relevo": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "agents.json",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "cli",
    "agents",
    "claude",
    "codex",
    "cursor",
    "repl",
    "tui",
    "ink"
  ],
  "license": "MIT",
  "author": "David Loor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davo20019/relevo.git"
  },
  "bugs": {
    "url": "https://github.com/davo20019/relevo/issues"
  },
  "homepage": "https://github.com/davo20019/relevo#readme"
}
